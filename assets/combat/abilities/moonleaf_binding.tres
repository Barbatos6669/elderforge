[resource]
script = ExtResource("1_definition")
ability_id = "moonleaf_binding"
display_name = "Moonleaf Binding"
description = "Crush the Moonleaf poultice sewn beneath the armor and bind your wounds. Channel for seven seconds outside combat while moving at half speed. Each pulse restores health and energy, but taking damage tears the binding open."
tooltip_tags = PackedStringArray("Healing", "Channel", "Survival", "Out of Combat")
tooltip_effects = Array[Resource]([SubResource("Resource_health"), SubResource("Resource_energy"), SubResource("Resource_movement"), SubResource("Resource_restriction")])
input_slot = &"r"
icon_id = "moonleaf_binding"
targeting_mode = "self"
execution_type = "regeneration"
energy_cost = 0.0
cooldown_seconds = 30.0
cast_duration_seconds = 7.0
requires_out_of_combat = true
cancel_on_damage = true
channel_tick_interval_seconds = 1.0
health_restore_percent_per_tick = 9.0
energy_restore_percent_per_tick = 7.5
movement_speed_multiplier = 0.5
