[resource]
script = ExtResource("1_definition")
ability_id = "leather_boots_roll"
display_name = "Dodge Roll"
description = "Aim along the ground while moving, then roll quickly in the chosen direction. A brief shield protects you during the roll, and collision shortens the movement rather than passing through obstacles."
