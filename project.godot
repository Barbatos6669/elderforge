; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="Elderforge"
run/main_scene="res://scenes/bootstrap/SignInGateway.tscn"
config/features=PackedStringArray("4.7", "Forward Plus")
config/icon="res://icon.svg"

[autoload]

PlayerDatabase="*res://scripts/persistence/player_database.gd"
PrototypeAuthSession="*res://scripts/auth/prototype_auth_session.gd"
AuctionMarket="*res://scripts/economy/auction_market.gd"

[display]

window/size/mode=3
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[filesystem]

import/blender/enabled=false

[layer_names]

3d_physics/layer_1="World"
3d_physics/layer_2="ResourceObstacle"
3d_physics/layer_3="PlayerHover"
3d_physics/layer_4="Selectable"
3d_physics/layer_5="Entity"

[physics]

3d/physics_engine="Jolt Physics"

[rendering]

rendering_device/driver.windows="d3d12"
